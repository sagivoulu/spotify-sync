{
  "name": "spotify-sync",
  "version": "0.1.0",
  "description": "CLI tool to sync a Spotify playlist to a local music library for west coast swing DJs",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "spotify-sync": "./bin/spotify-sync"
  },
  "scripts": {
    "setup": "npm install && npm run build",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "smoke:download": "tsx scripts/smoke-test-download.ts"
  },
  "dependencies": {
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^12.0.0",
    "node-id3": "^0.2.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  }
}
